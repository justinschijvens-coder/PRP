pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/JOUW_GITHUB/PRP.git'
            }
        }

        stage('Build & Deploy') {
            steps {
                sh '''
                    docker compose down || true
                    docker compose build
                    docker compose up -d
                '''
            }
        }
    }
}
