pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/JOUW_REPO.git'
            }
        }

        stage('Build Docker image') {
            steps {
                sh 'docker build -t mijn-app .'
            }
        }

        stage('Run container') {
            steps {
                sh '''
                    docker stop mijn-app || true
                    docker rm mijn-app || true
                    docker run -d -p 8080:80 --name mijn-app mijn-app
                '''
            }
        }
    }
}
