pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/justinschijvens-coder/PRP.git .'
            }
        }

        stage('Build Docker image') {
            steps {
                sh 'docker build -t apache2-orthia .'
            }
        }

        stage('Run container') {
            steps {
                sh '''
                    docker stop apache2-orthia || true
                    docker rm apache2-orthia || true
                    docker run -d -p 8080:80 --name apache2-orthia apache2-orthia
                '''
            }
        }
    }
}
